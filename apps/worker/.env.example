# Dry-run / paper-trading mode
# When true, EthereumExecutor logs intended BUY/SELL/approval transactions instead of signing and broadcasting them.
# Keep this true until you've verified the full pipeline end-to-end; set to false only when ready to trade with real funds.
DRY_RUN=true

API_OLLAMA_URL=

# OpenRouter API Key
OPENROUTER_API_URL=
OPENROUTER_API_KEY=

SYSTEM_PROMPT="You are a crypto trading analyst."
LLM_PROVIDER="replicate"
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME="google/gemini-2.5-flash"
LLM_ADAPTER_CLASS="ReplicateAdapter"
LLM_REPLICATE_PREDICTION_TIMEOUT_SECONDS=120

REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
