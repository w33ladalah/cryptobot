# After filling in the values below, run: cd apps/worker && python -m core.preflight
# Base settings
APP_ENV=
APP_DEBUG=

# API settings
API_BASE_URL=
API_PORT=
API_ENCRYPTION_SECRET_KEY=
API_RATE_LIMIT=

# Database
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_HOST=
MYSQL_PORT=

# Data sources
DEXSCREENER_API=
COINGECKO_API=
COINGECKO_API_KEY=

# Discord
DISCORD_BOT_TOKEN=

# Wallet
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

# Dry-run / paper-trading mode
# When true, EthereumExecutor logs intended BUY/SELL/approval transactions instead of signing and broadcasting them.
# Keep this true until you've verified the full pipeline end-to-end; set to false only when ready to trade with real funds.
DRY_RUN=true

# Ollama API
API_OLLAMA_URL=

# OpenRouter API Key
OPENROUTER_API_URL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL_NAME=

# LLM
SYSTEM_PROMPT="You are a crypto trading analyst."
LLM_PROVIDER="replicate"
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME="google/gemini-2.5-flash"
LLM_ADAPTER_CLASS="ReplicateAdapter"

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Worker settings
WORKER_BACKEND_API=

# Infura settings
# Sign up for a free project at https://app.infura.io (or use Alchemy's equivalent) and
# swap in your own project ID below. INFURA_URL_TESTNET is the only one this worker reads
# (network="testnet" in EthereumExecutor) — INFURA_URL_MAINNET is unused until mainnet trading.
INFURA_URL_MAINNET=
INFURA_URL_TESTNET=

# Uniswap settings
# Sepolia V2Router02 (see developers.uniswap.org/docs/protocols/v2/deployments): 0xeE567Fe1712Faf6149d80dA1E6934E354124CfE3
UNISWAP_ROUTER_ADDRESS=

# WETH contract address for the target network. Mainnet and Sepolia WETH addresses differ.
# Mainnet WETH: 0xC02aaa39b223FE8D0A0e5C4F27ead9083C756Cc2
# Sepolia WETH example (used by active USDC/WETH pool): 0xfff9976782d46cc05630d1f6ebab18b2324d6b14
# Note: Sepolia WETH deployments can vary by faucet/pool — verify against the pool you're testing.
WETH_ADDRESS=
